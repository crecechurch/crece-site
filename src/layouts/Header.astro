---
import NavMenu from "@/components/NavMenu";
import Sidebar from "@/components/Sidebar";
import StyledText from "@/components/StyledText";
import { menu as originalMenu } from "@/utils/getMenuItems";
import { Image } from "astro:assets";
import { type ImageMetadata } from "astro";
import { siteConfig } from "@/data/contentCollectionDataFetching";

const logoImage = import.meta.glob<{ default: ImageMetadata }>(`src/assets/*`);

const currentPath = Astro.url.pathname;

const menu = [
  { label: "Inicio", path: "", order: 0, type: null, submenu: [] },
  ...originalMenu
];
---

<header
  class:list={["layout-full py-4", currentPath !== "/" && "bg-muted"]}
>
  <div class="flex w-full items-center justify-between flex-1">

    <!-- Brand block: stays together on ALL screen sizes -->
    <div class="flex items-center gap-4 sm:gap-6 flex-shrink-0">
      {
        siteConfig?.data.header?.displayLogo && siteConfig.data.general.logo && (
          <div class="size-14 sm:size-16 rounded-full overflow-hidden shrink-0 min-w-max">
            <Image
              src={logoImage[`/${siteConfig.data.general.logo}`]()}
              alt="logo"
              class="w-full h-full object-cover"
            />
          </div>
        )
      }

      {
        siteConfig?.data.header?.displayTitle ? (
          <StyledText
            as="h2"
            variant="displayLG"
            className="block whitespace-nowrap text-lg sm:text-xl md:text-2xl lg:text-3xl"
          >
            <a href="/">{siteConfig?.data.general.name}</a>
          </StyledText>
        ) : (
          <h2 class="sr-only">{siteConfig?.data.general.name}</h2>
        )
      }
    </div>

    <!-- Desktop Nav -->
    <NavMenu
      className="hidden lg:inline-flex gap-2 items-center flex-wrap"
      menu={menu}
      client:load
    />

    <!-- Mobile Sidebar -->
    <Sidebar menu={menu} client:load />
  </div>
</header>
